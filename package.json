  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/tabler": "^1.2.31",
    "@pagefind/default-ui": "^1.5.0",
    "@types/bun": "^1.3.12",
    "eslint-plugin-oxlint": "^1.55.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "wrangler": "^4.73.0"
  },
  "name": "astro-erudite",
  "prettier": {
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ],
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "semi": true,
    "singleQuote": false
  },
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "deploy": "astro build && wrangler pages deploy --commit-dirty=true",
    "dev": "astro dev",
    "format": "prettier --write **/*.{ts,tsx,css,astro} --ignore-path .gitignore",
    "lint": "oxlint --fix",
    "new:article": "bun run --bun ./utils/new-article.ts",
    "postinstall": "patch-package",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "type": "module",
  "version": "1.6.2"
}
