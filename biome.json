{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "preset": "recommended",
        "useSortedAttributes": "on",
        "useSortedKeys": "on",
        "useSortedProperties": "on"
      }
    },
    "enabled": true,
    "includes": ["**", "!**/src/components/ui/**/*.tsx"]
  },
  "files": {
    "includes": [
      "**/*.{ts,mjs,json,astro}",
      "**/src/**/*.{ts,tsx}",
      "**/__tests__/**/*.test.ts",
      "!**/lib/*.{ts,mjs,json}",
      "!**/node_modules/**/*",
      "!**/.astro/**/*",
      "!**/.claude/**/*",
      "!**/src/components/ui/**/*.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "includes": ["**"],
    "indentStyle": "space",
    "useEditorconfig": true
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "single",
      "lineWidth": 120,
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "enabled": true,
    "includes": ["**"],
    "rules": {
      "a11y": {},
      "correctness": {},
      "nursery": {},
      "preset": "recommended",
      "style": {},
      "suspicious": {}
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "suspicious": {
            "noRedeclare": "off"
          }
        }
      }
    }
  ]
}
